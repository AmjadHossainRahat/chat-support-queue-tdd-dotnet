FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /workspace

COPY . .

WORKDIR /workspace/src/SupportChat.Worker
RUN dotnet restore "SupportChat.Worker.csproj"
RUN dotnet publish "SupportChat.Worker.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/runtime:10.0 AS final
WORKDIR /app

COPY --from=build /app/publish .

ENV DOTNET_ENVIRONMENT=Production

ENTRYPOINT ["dotnet", "SupportChat.Worker.dll"]